{
  "name": "react-ai-analyzer",
  "displayName": "React AI Analyzer",
  "description": "An AI-powered React code analyzer for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:react-ai-analyzer.analyze",
    "onCommand:react-ai-analyzer.indexWorkspace"
  ],
  "main": "./out/extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "react-ai-analyzer.analyze",
        "title": "Analyze React Code"
      },
      {
        "command": "react-ai-analyzer.indexWorkspace",
        "title": "Index Workspace for Analysis"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "react-ai-analyzer.analyze",
          "when": "editorTextFocus && (resourceLangId == javascript || resourceLangId == javascriptreact || resourceLangId == typescript || resourceLangId == typescriptreact)",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "react-ai-analyzer.analyze",
          "when": "resourceExtname == .js || resourceExtname == .jsx || resourceExtname == .ts || resourceExtname == .tsx",
          "group": "navigation@10"
        }
      ],
      "explorer/context": [
        {
          "command": "react-ai-analyzer.analyze",
          "when": "resourceExtname == .js || resourceExtname == .jsx || resourceExtname == .ts || resourceExtname == .tsx",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "axios": "^1.6.2",
    "langchain": "^0.0.207",
    "node-fetch": "^3.3.2",
    "tree-sitter": "^0.20.6",
    "tree-sitter-typescript": "^0.20.3",
    "vscode": "^1.1.37"
  }
}
